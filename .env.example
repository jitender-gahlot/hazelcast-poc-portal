# ── Copy this file to .env and fill in real values ──────────────────────────
# TLS is handled by Cloudflare — no cert config needed here.

# PostgreSQL
POSTGRES_DB=pocportal
POSTGRES_USER=pocuser
POSTGRES_PASSWORD=change-me-strong-password   # min 16 chars recommended

# JWT — generate with: openssl rand -hex 32  (must be ≥32 chars)
JWT_SECRET=change-me-to-a-64-char-random-secret

# Internal access code for SE/AE self-registration (min 12 chars, no defaults)
ADMIN_REGISTRATION_CODE=change-me-12chars+

# Cloudflare terminates TLS so the browser always connects over HTTPS.
# Keep this true. Only set to false for local HTTP-only dev without Cloudflare.
COOKIE_SECURE=true

# Port nginx listens on — Cloudflare proxies to this port on the Mac Studio.
# Default 80 (HTTP). Cloudflare handles the HTTPS side.
HOST_PORT=80

# ── Backups ───────────────────────────────────────────────────────────────────
BACKUP_RETAIN_DAYS=7           # keep backups for this many days
BACKUP_INTERVAL_SECONDS=21600  # dump every 6 hours

# Log level: error | warn | info | debug
LOG_LEVEL=info
