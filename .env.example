# ── Copy this file to .env and fill in real values ──────────────────────────

# PostgreSQL
POSTGRES_DB=pocportal
POSTGRES_USER=pocuser
POSTGRES_PASSWORD=change-me-strong-password

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-64-char-random-secret

# Internal access code for SE/AE registration
ADMIN_REGISTRATION_CODE=SE2024

# Host port to expose (default 8080)
HOST_PORT=8080

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Set to true ONLY when the app is served over HTTPS (TLS termination configured)
# Leaving this false (default) allows the auth cookie to work over plain HTTP
COOKIE_SECURE=false
