# ── Copy this file to .env and fill in real values ──────────────────────────

# PostgreSQL
POSTGRES_DB=pocportal
POSTGRES_USER=pocuser
POSTGRES_PASSWORD=change-me-strong-password   # min 16 chars recommended

# JWT — generate with: openssl rand -hex 32  (must be ≥32 chars)
JWT_SECRET=change-me-to-a-64-char-random-secret

# Internal access code for SE/AE self-registration (min 12 chars, no defaults)
ADMIN_REGISTRATION_CODE=change-me-12chars+

# ── HTTPS (Caddy) ────────────────────────────────────────────────────────────
# Set DOMAIN to your public hostname for automatic Let's Encrypt cert.
# Leave as localhost for a self-signed cert (local/staging only).
DOMAIN=localhost
TLS_EMAIL=you@example.com   # required for Let's Encrypt; ignored for localhost

# Set to true ONLY when the app is behind HTTPS (i.e. Caddy is running)
COOKIE_SECURE=false

# ── Local HTTP access (ignored when Caddy handles traffic) ────────────────────
HOST_PORT=8090

# ── Backups ──────────────────────────────────────────────────────────────────
BACKUP_RETAIN_DAYS=7           # keep backups for this many days
BACKUP_INTERVAL_SECONDS=21600  # backup every 6 hours

# Log level: error | warn | info | debug
LOG_LEVEL=info
